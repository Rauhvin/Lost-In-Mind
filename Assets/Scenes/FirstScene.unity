    m_Modifications:
    - target: {fileID: 4573627944131785250, guid: 8870a2dbc1e150b45949c75107370e0d, type: 3}
      propertyPath: fullText
      value: "<b>Day <color=red>#14</color></b>\n\nThey told me the treatment would
        help. They lied. \nEvery time I close my eyes, I hear the crackling of the
        fire and...\n\rIf anyone finds this... tell her I\u2019m sorry. \nI tried
        to help you,  I really tried... . \n<b><size=120%>HELP ME.</size></b>"
      objectReference: {fileID: 0}
    - target: {fileID: 4573627944131785250, guid: 8870a2dbc1e150b45949c75107370e0d, type: 3}
      propertyPath: noteTitle
